{
  "name": "glialnode",
  "version": "0.1.0",
  "description": "Tiered memory infrastructure for orchestrators, agents, and subagents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "default": "./dist/dashboard/index.js"
    },
    "./execution-context": {
      "types": "./dist/execution-context/index.d.ts",
      "default": "./dist/execution-context/index.js"
    },
    "./metrics": {
      "types": "./dist/metrics/index.d.ts",
      "default": "./dist/metrics/index.js"
    },
    "./cli": {
      "default": "./dist/cli/index.js"
    }
  },
  "bin": {
    "glialnode": "dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "!dist/test/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "demo:client": "node scripts/client-demo.mjs",
    "demo:dashboard": "npm run build && node scripts/dashboard-fixture.mjs",
    "demo": "node scripts/demo.mjs",
    "demo:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo.ps1",
    "example:agent-loop": "node examples/agent-loop/loop.mjs",
    "example:service": "node examples/memory-service/service.mjs",
    "bench": "node scripts/benchmark.mjs",
    "bench:provenance": "node scripts/benchmark-provenance.mjs",
    "eval:semantic": "npm run build && node dist/cli/index.js memory semantic-eval --corpus docs/evals/retrieval-corpus.v1.json --output docs/evals/semantic-eval.latest.json --json",
    "pack:check": "npm run build && node scripts/check-pack.mjs",
    "start": "node dist/cli/index.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "keywords": [
    "memory",
    "agents",
    "orchestrators",
    "sqlite",
    "fts5"
  ],
  "author": "Sepulveda1387",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.8.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sepulveda1387/GlialNode.git"
  },
  "bugs": {
    "url": "https://github.com/Sepulveda1387/GlialNode/issues"
  },
  "homepage": "https://github.com/Sepulveda1387/GlialNode#readme"
}
